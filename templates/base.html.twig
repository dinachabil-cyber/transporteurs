<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Expert en assurance transport. Devis gratuit pour camion, flotte, fret.">
    <title>{% block title %}Aksam Assurance - Devis Gratuit{% endblock %}</title>

    {# Fonts #}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

    {# Styles #}
    {% block stylesheets %}
        {{ encore_entry_link_tags('app') }}
        <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">

        <style>
            :root {
                --color-primary: #065F46;
                --color-secondary: #047857;
                --color-accent: #F59E0B;
                --color-soft: #ECFDF5;
            }

            html {
                scroll-behavior: smooth;
            }

            body {
                font-family: 'Inter', sans-serif;
            }

            .bg-primary {
                background-color: var(--color-primary);
            }

            .text-primary {
                color: var(--color-primary);
            }

            .border-primary {
                border-color: var(--color-primary);
            }

            .glass {
                background: rgba(255, 255, 255, 0.78);
                backdrop-filter: blur(16px);
                -webkit-backdrop-filter: blur(16px);
                border: 1px solid rgba(255, 255, 255, 0.45);
                box-shadow: 0 10px 35px rgba(6, 95, 70, 0.10);
            }

            .hero-glow {
                position: relative;
                overflow: hidden;
            }

            .hero-glow::before {
                content: "";
                position: absolute;
                inset: -30%;
                background: radial-gradient(circle, rgba(16,185,129,0.18) 0%, rgba(255,255,255,0) 60%);
                pointer-events: none;
            }

            .animated-title {
                background: linear-gradient(90deg, #065F46 0%, #10B981 35%, #F59E0B 55%, #10B981 75%, #065F46 100%);
                background-size: 220% auto;
                -webkit-background-clip: text;
                background-clip: text;
                color: transparent;
                animation: shineText 6s linear infinite;
            }

            .float-soft {
                animation: floatSoft 4s ease-in-out infinite;
            }

            .fade-up {
                animation: fadeUp 0.7s ease-out both;
            }

            .pulse-soft {
                animation: pulseSoft 2.5s ease-in-out infinite;
            }

            .nav-link {
                position: relative;
                transition: all 0.3s ease;
            }

            .nav-link::after {
                content: "";
                position: absolute;
                left: 0;
                bottom: -4px;
                width: 0;
                height: 2px;
                background: #F59E0B;
                transition: width 0.3s ease;
            }

            .nav-link:hover::after {
                width: 100%;
            }

            @keyframes shineText {
                0% {
                    background-position: 0% center;
                }
                100% {
                    background-position: 220% center;
                }
            }

            @keyframes fadeUp {
                from {
                    opacity: 0;
                    transform: translateY(18px);
                }
                to {
                    opacity: 1;
                    transform: translateY(0);
                }
            }

            @keyframes floatSoft {
                0%, 100% {
                    transform: translateY(0px);
                }
                50% {
                    transform: translateY(-4px);
                }
            }

            @keyframes pulseSoft {
                0%, 100% {
                    box-shadow: 0 0 0 0 rgba(245, 158, 11, 0.18);
                }
                50% {
                    box-shadow: 0 0 0 8px rgba(245, 158, 11, 0);
                }
            }

            @media (max-width: 768px) {
                .animated-title {
                    animation-duration: 8s;
                }
            }
        </style>
    {% endblock %}
</head>

<body class="bg-gray-50 min-h-screen flex flex-col text-gray-800">

    {# Header #}
    {% block header %}
    <header >
        <div class="relative bg-white/70 backdrop-blur-xl border-b border-white/40 shadow-sm">
            <div class="pointer-events-none absolute -top-10 left-10 w-40 h-40 bg-green-200 opacity-20 rounded-full blur-3xl"></div>
            <div class="pointer-events-none absolute -top-10 right-10 w-40 h-40 bg-amber-200 opacity-20 rounded-full blur-3xl"></div>

            <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
                <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">

                    <a href="{{ path('homepage') }}" class="flex items-center gap-4 group">
                        <div class="w-12 h-12 rounded-2xl glass flex items-center justify-center text-xl shadow-md float-soft">
                            🚚
                        </div>

                        <div class="hero-glow">
                            <p class="text-xs uppercase tracking-[0.25em] text-green-700 font-semibold mb-1">
                                AKSAM ASSURANCE
                            </p>

                            <h1 class="text-lg sm:text-xl md:text-2xl font-extrabold tracking-tight animated-title leading-tight">
                                Professionnels du transport, obtenez votre devis en quelques clics
                            </h1>

                            <p class="text-sm text-gray-500 mt-1 fade-up">
                                Solution rapide, claire et sécurisée pour vos besoins d’assurance transport
                            </p>
                        </div>
                    </a>

                    <div class="flex items-center gap-3 flex-wrap">
                        <span class="inline-flex items-center px-4 py-2 rounded-full bg-green-50 text-green-800 text-sm font-semibold border border-green-100 shadow-sm">
                            ⭐ Service fiable
                        </span>
                        <span class="inline-flex items-center px-4 py-2 rounded-full bg-amber-50 text-amber-700 text-sm font-semibold border border-amber-100 shadow-sm pulse-soft">
                            🚀 Devis rapide
                        </span>
                    </div>

                </div>
            </div>
        </div>
    </header>
    {% endblock %}

    {# Flash Messages #}
    {% block flash_messages %}
    <div class="max-w-7xl mx-auto w-full px-4 sm:px-6 lg:px-8 py-4">
        {% for type, messages in app.flashes %}
            {% for message in messages %}
                <div class="mb-4 p-4 rounded-2xl shadow-sm border fade-up {% if type == 'success' %}bg-green-50 text-green-800 border-green-200{% else %}bg-red-50 text-red-800 border-red-200{% endif %}">
                    {{ message }}
                </div>
            {% endfor %}
        {% endfor %}
    </div>
    {% endblock %}

    {# Main Content #}
    <main class="flex-grow">
        {% block body %}{% endblock %}
    </main>

    {# Footer #}
    {% block footer %}
<footer class="bg-green-900 text-green-300 py-10 mt-16">

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

        <div class="grid md:grid-cols-3 gap-8">

            {# Logo #}
            <div>
                <h3 class="text-white font-bold text-lg mb-3">
                    Aksam Assurance
                </h3>
                <p class="text-sm text-gray-400">
                    Assurance transport pour professionnels. Simple, rapide et efficace.
                </p>
            </div>

            {# Links #}
            <div>
                <h4 class="text-white font-semibold mb-3">
                    Informations
                </h4>
                <ul class="space-y-2 text-sm">
                    <li>
                        <a href="{{ path('front_mentions_legales') }}" class="hover:text-white transition">
                            Mentions légales
                        </a>
                    </li>
                    <li>
                        <a href="{{ path('front_politique_confidentialite') }}" class="hover:text-white transition">
    Politique de confidentialité
</a>
                    </li>
                </ul>
            </div>

            {# Contact #}
            <div>
                <h4 class="text-white font-semibold mb-3">
                    Contact
                </h4>
                <ul class="space-y-2 text-sm text-gray-400">
                    <li>📍 Paris</li>
                    <li>📞 01 23 45 67 89</li>
                    <li>✉️ contact@aksam-assurance.fr</li>
                </ul>
            </div>

        </div>

        <div class="border-t border-gray-800 mt-8 pt-6 text-center text-sm text-gray-500">
            © {{ "now"|date("Y") }} Aksam Assurance
        </div>

    </div>

</footer>
{% endblock %}
    {# Scripts #}
    {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {{ encore_entry_script_tags('app') }}
    {% endblock %}
</body>
</html>