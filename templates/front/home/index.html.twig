                        </div>

                        <div class="grid grid-cols-2 gap-3">
                            <div>
                                <label class="block text-xs font-medium text-theme-gray-700 mb-1">{{ 'form_start_activity'|trans }}</label>
                                <select name="start_activity" required
                                    class="w-full px-3 py-2.5 text-sm border border-gray-300 rounded-xl focus:ring-2 focus:ring-green-500 transition bg-white/90">
                                    <option value="">{{ 'form_select_choose'|trans }}</option>
                                    <option value="1">{{ 'form_select_yes'|trans }}</option>
                                    <option value="0">{{ 'form_select_no'|trans }}</option>
                                </select>
                            </div>
                            <div>
                                <label class="block text-xs font-medium text-theme-gray-700 mb-1">{{ 'form_insured_currently'|trans }}</label>
                                <select name="insured_currently" required
                                    class="w-full px-3 py-2.5 text-sm border border-gray-300 rounded-xl focus:ring-2 focus:ring-green-500 transition bg-white/90">
                                    <option value="">{{ 'form_select_choose'|trans }}</option>
                                    <option value="1">{{ 'form_select_yes'|trans }}</option>
                                    <option value="0">{{ 'form_select_no'|trans }}</option>
                                </select>
                            </div>
                        </div>

                        <div>
                            <label class="block text-xs font-medium text-theme-gray-700 mb-1">{{ 'form_previous_resiliation'|trans }}</label>
                            <select id="previous_resiliation" name="previous_resiliation" required
                                class="w-full px-3 py-2.5 text-sm border border-gray-300 rounded-xl focus:ring-2 focus:ring-green-500 transition bg-white/90">
                                <option value="">{{ 'form_select_choose'|trans }}</option>
                                <option value="sinistre">{{ 'form_resiliation_sinistre'|trans }}</option>
                                <option value="non_paiement">{{ 'form_resiliation_non_paiement'|trans }}</option>
                                <option value="suspension_permis">{{ 'form_resiliation_suspension'|trans }}</option>
                                <option value="fausse_declaration">{{ 'form_resiliation_fausse_declaration'|trans }}</option>
                                <option value="echeance">{{ 'form_resiliation_echeance'|trans }}</option>
                                <option value="non">{{ 'form_resiliation_non'|trans }}</option>
                            </select>
                        </div>

                        <div id="motif_container" class="hidden">
                            <label class="block text-xs font-medium text-theme-gray-700 mb-1">{{ 'form_resiliation_motif'|trans }}</label>
                            <textarea name="resiliation_motif" rows="2"
                                class="w-full px-3 py-2.5 text-sm border border-gray-300 rounded-xl focus:ring-2 focus:ring-green-500 transition bg-white/90"
                                placeholder="{{ 'form_placeholder_motif'|trans }}"></textarea>
                        </div>

                        <div class="grid grid-cols-2 gap-3">
                            <div>
                                <label class="block text-xs font-medium text-theme-gray-700 mb-1">{{ 'form_postcode'|trans }}</label>
