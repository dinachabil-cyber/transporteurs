                            </div>
                            <div>
                                <label class="block text-xs font-medium text-theme-gray-700 mb-1">{{ 'form_phone'|trans }}</label>
                                <input type="tel" name="phone" required
                                    class="w-full px-3 py-2.5 text-sm border border-gray-300 rounded-xl focus:ring-2 focus:ring-green-500 transition bg-white/90"
