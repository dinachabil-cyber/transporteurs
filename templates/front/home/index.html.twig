                        <div class="bg-white/90 backdrop-blur-md rounded-2xl p-4 shadow-lg border border-theme-gray-200 hover-lift">
                            <div class="flex items-center justify-between flex-wrap gap-3">
                                <div>
                                    <p class="text-sm text-theme-gray-500">{{ 'home_broker'|trans }}</p>
                                    <h2 class="text-xl md:text-2xl font-extrabold text-theme-green-700 tracking-tight mb-1">
                                        {{ 'home_insurance_title'|trans }}
                                    </h2>
                                </div>
