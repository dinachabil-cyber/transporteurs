                    <div class="rounded-2xl border border-theme-gray-200 bg-theme-gray-50 p-4 text-sm font-medium text-theme-gray-700 hover-lift">{{ 'solution_van_light'|trans }}</div>
                    <div class="rounded-2xl border border-theme-gray-200 bg-theme-gray-50 p-4 text-sm font-medium text-theme-gray-700 hover-lift">{{ 'solution_light_transport'|trans }}</div>
                    <div class="rounded-2xl border border-theme-gray-200 bg-theme-gray-50 p-4 text-sm font-medium text-theme-gray-700 hover-lift">{{ 'solution_fleet'|trans }}</div>
                </div>
            </section>

            {# CTA #}
            <section class="relative overflow-hidden bg-theme-green-700 text-white rounded-3xl shadow-xl p-8 hover:shadow-2xl transition duration-500 animate-fade-in-up cta-animate hover-glow">
                <div class="absolute -top-6 -right-6 w-28 h-28 bg-white/10 rounded-full animate-pulse-slow"></div>
                <div class="absolute -bottom-8 -left-8 w-36 h-36 bg-white/10 rounded-full animate-pulse-slow"></div>
                <div class="relative z-10 text-center">
                    <p class="text-green-100 text-sm mb-2">{{ 'cta_subtitle'|trans }}</p>
                    <h2 class="text-2xl md:text-3xl font-bold mb-6">{{ 'cta_title'|trans }}</h2>
