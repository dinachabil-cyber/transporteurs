                            </div>
                        </div>

                        <div>
                            <label class="block text-xs font-medium text-theme-gray-700 mb-1">{{ 'form_email'|trans }}</label>
                            <input type="email" name="email" required
                                class="w-full px-3 py-2.5 text-sm border border-gray-300 rounded-xl focus:ring-2 focus:ring-green-500 transition bg-white/90"
                                placeholder="{{ 'form_placeholder_email'|trans }}">
                        </div>
                    </div>

                    <div class="mt-auto pt-4">
                        <div class="bg-theme-gray-50/90 border border-theme-gray-200 rounded-xl p-3 mb-3">
                            <div class="flex items-start gap-2">
                                <div class="text-theme-green-700 text-sm">🔒</div>
                                <p class="text-xs text-theme-gray-600 leading-5">{{ 'form_privacy_notice'|trans }}</p>
                            </div>
                        </div>

                        <button type="submit"
                            class="w-full bg-theme-green-700 hover:bg-theme-green-800 text-white font-semibold py-3 rounded-xl shadow-lg hover:shadow-xl transform hover:-translate-y-0.5 transition duration-300 animate-shimmer hover-glow">
                            {{ 'form_submit'|trans }}
                        </button>

                        <div class="grid grid-cols-3 gap-2 text-center text-xs text-theme-gray-500 mt-3">
                            <div class="bg-theme-green-50 rounded-lg py-1.5 hover-lift">{{ 'form_badge_free'|trans }}</div>
                            <div class="bg-theme-green-50 rounded-lg py-1.5 hover-lift">{{ 'form_badge_fast'|trans }}</div>
                            <div class="bg-theme-green-50 rounded-lg py-1.5 hover-lift">{{ 'form_badge_secure'|trans }}</div>
                        </div>
                    </div>
                </form>
            </div>
        </div>

