                                    <span class="text-sm text-theme-gray-600 ml-2 font-medium">{{ 'home_rating'|trans }}</span>
                                </div>
                            </div>
                        </div>
                    </div> #}
                </div>
            </div>

            {# RIGHT - Form #}
            <div class="bg-white/80 backdrop-blur-xl rounded-3xl shadow-xl p-6 border border-theme-gray-200 flex flex-col animate-fade-in-up delay-200 hover-lift hover-glow">
                <div class="mb-4">
                    <div class="inline-flex items-center gap-2 bg-theme-green-100 text-theme-green-800 px-3 py-1.5 rounded-full text-xs font-semibold mb-2 shadow-sm">
                        {{ 'home_form_secure'|trans }}
                    </div>
                    <h2 class="text-xl font-bold text-gray-900">{{ 'home_form_title'|trans }}</h2>
                    <p class="text-theme-gray-600 text-sm mt-1">{{ 'home_form_subtitle'|trans }}</p>
                </div>

                <form action="{{ path('quote_create', {_locale: app.request.locale}) }}" method="POST" id="quote-form" class="flex-1 flex flex-col">
                    <div class="space-y-3 flex-1">
                        <div class="grid grid-cols-2 gap-3">
                            <div>
                                <label class="block text-xs font-medium text-theme-gray-700 mb-1">{{ 'form_lastname'|trans }}</label>
                                <input type="text" name="lastname" required
                                    class="w-full px-3 py-2.5 text-sm border border-gray-300 rounded-xl focus:ring-2 focus:ring-green-500 focus:border-green-500 transition bg-white/90"
                                    placeholder="{{ 'form_placeholder_lastname'|trans }}">
                            </div>
                            <div>
                                <label class="block text-xs font-medium text-theme-gray-700 mb-1">{{ 'form_firstname'|trans }}</label>
                                <input type="text" name="firstname" required
                                    class="w-full px-3 py-2.5 text-sm border border-gray-300 rounded-xl focus:ring-2 focus:ring-green-500 focus:border-green-500 transition bg-white/90"
                                    placeholder="{{ 'form_placeholder_firstname'|trans }}">
                            </div>
                        </div>

                        <div>
                            <label class="block text-xs font-medium text-theme-gray-700 mb-1">{{ 'form_company'|trans }}</label>
                            <input type="text" name="company"
                                class="w-full px-3 py-2.5 text-sm border border-gray-300 rounded-xl focus:ring-2 focus:ring-green-500 focus:border-green-500 transition bg-white/90"
