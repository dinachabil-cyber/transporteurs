{% extends 'base.html.twig' %}

{% block body %}

<section class="bg-gray-100 py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid lg:grid-cols-2 gap-10 items-center">

            <!-- LEFT: IMAGE -->
            <div class="bg-yellow-400 rounded-3xl p-8 flex justify-center">
                <img src="/images/taxi.jpg" class="rounded-2xl w-full max-w-md">
            </div>

            <!-- RIGHT: FORM -->
            <div class="bg-white rounded-3xl shadow-xl p-8">
                <h2 class="text-2xl font-bold text-yellow-500 mb-6 text-center">
                    Complétez ce formulaire
                </h2>

                <form class="space-y-4">
                    <input type="text" placeholder="Raison sociale..."
                        class="w-full border rounded-lg px-4 py-3">

                    <input type="text" placeholder="Votre Nom"
                        class="w-full border rounded-lg px-4 py-3">

                    <input type="text" placeholder="Téléphone"
                        class="w-full border rounded-lg px-4 py-3">

                    <button class="w-full bg-yellow-400 py-3 rounded-lg font-bold">
                        Comparer maintenant
                    </button>
                </form>
            </div>

        </div>
    </div>
</section>

{% endblock %}