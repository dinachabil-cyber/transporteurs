{% extends 'base.html.twig' %}

{% block title %}{{ 'privacy_title'|trans }}{% endblock %}

{% block body %}
<div class="min-h-screen bg-theme-gradient py-12 px-4">
    <div class="max-w-5xl mx-auto space-y-8">

        {# HERO #}
        <div class="text-center">
            <span class="inline-flex items-center px-4 py-2 rounded-full bg-theme-green-100 text-theme-green-800 text-sm font-semibold mb-4">
                {{ 'privacy_badge'|trans }}
            </span>
            <h1 class="text-3xl md:text-4xl font-bold text-theme-gray-900 mb-4">
                {{ 'privacy_title'|trans }}
            </h1>
            <p class="text-theme-gray-600 max-w-2xl mx-auto leading-7">
                {{ 'privacy_intro'|trans }}
            </p>
        </div>

        {# 1 - RESPONSABLE #}
        <section class="bg-white rounded-2xl shadow-md p-6 border border-theme-gray-100 hover:shadow-lg transition">
            <div class="flex items-center gap-3 mb-4">
                <div class="w-10 h-10 rounded-full bg-theme-green-100 flex items-center justify-center text-theme-green-700 font-bold">1</div>
                <h2 class="text-xl font-bold text-theme-gray-900">{{ 'privacy_responsible'|trans }}</h2>
            </div>
            <p class="text-theme-gray-700 leading-7">{{ 'privacy_responsible_desc'|trans }}</p>
        </section>

        {# 2 - DONNEES #}
        <section class="bg-white rounded-2xl shadow-md p-6 border border-theme-gray-100 hover:shadow-lg transition">
            <div class="flex items-center gap-3 mb-5">
                <div class="w-10 h-10 rounded-full bg-theme-green-100 flex items-center justify-center text-theme-green-700 font-bold">2</div>
                <h2 class="text-xl font-bold text-theme-gray-900">{{ 'privacy_data_collected'|trans }}</h2>
            </div>
            <div class="grid md:grid-cols-2 gap-4">
                <div class="rounded-xl border border-gray-200 bg-gray-50 p-5">
                    <h3 class="font-semibold text-gray-900 mb-2">{{ 'privacy_data_user'|trans }}</h3>
                    <ul class="list-disc pl-5 text-sm text-gray-700 space-y-2">
                        <li>{{ 'privacy_data_user_name'|trans }}</li>
                        <li>{{ 'privacy_data_user_vehicle'|trans }}</li>
                        <li>{{ 'privacy_data_user_license'|trans }}</li>
                        <li>{{ 'privacy_data_user_contracts'|trans }}</li>
                    </ul>
                </div>
                <div class="rounded-xl border border-gray-200 bg-gray-50 p-5">
                    <h3 class="font-semibold text-gray-900 mb-2">{{ 'privacy_data_auto'|trans }}</h3>
                    <ul class="list-disc pl-5 text-sm text-gray-700 space-y-2">
                        <li>{{ 'privacy_data_auto_ip'|trans }}</li>
                        <li>{{ 'privacy_data_auto_date'|trans }}</li>
                        <li>{{ 'privacy_data_auto_browser'|trans }}</li>
                        <li>{{ 'privacy_data_auto_pages'|trans }}</li>
                    </ul>
                </div>
            </div>
        </section>

        {# 3 - FINALITES #}
        <section class="bg-white rounded-2xl shadow-md p-6 border border-theme-gray-100 hover:shadow-lg transition">
            <div class="flex items-center gap-3 mb-5">
                <div class="w-10 h-10 rounded-full bg-theme-green-100 flex items-center justify-center text-theme-green-700 font-bold">3</div>
                <h2 class="text-xl font-bold text-theme-gray-900">{{ 'privacy_purposes'|trans }}</h2>
            </div>
            <div class="grid sm:grid-cols-2 gap-4">
                <div class="rounded-xl bg-green-50 border border-green-100 p-4 text-sm text-gray-700">{{ 'privacy_purpose_quote'|trans }}</div>
                <div class="rounded-xl bg-green-50 border border-green-100 p-4 text-sm text-gray-700">{{ 'privacy_purpose_contract'|trans }}</div>
                <div class="rounded-xl bg-green-50 border border-green-100 p-4 text-sm text-gray-700">{{ 'privacy_purpose_client'|trans }}</div>
                <div class="rounded-xl bg-green-50 border border-green-100 p-4 text-sm text-gray-700">{{ 'privacy_purpose_improve'|trans }}</div>
                <div class="rounded-xl bg-green-50 border border-green-100 p-4 text-sm text-gray-700">{{ 'privacy_purpose_marketing'|trans }}</div>
                <div class="rounded-xl bg-green-50 border border-green-100 p-4 text-sm text-gray-700">{{ 'privacy_purpose_legal'|trans }}</div>
            </div>
        </section>

        {# 4 - DESTINATAIRES #}
        <section class="bg-white rounded-2xl shadow-md p-6 border border-theme-gray-100 hover:shadow-lg transition">
            <div class="flex items-center gap-3 mb-4">
                <div class="w-10 h-10 rounded-full bg-theme-green-100 flex items-center justify-center text-theme-green-700 font-bold">4</div>
                <h2 class="text-xl font-bold text-theme-gray-900">{{ 'privacy_recipients'|trans }}</h2>
            </div>
            <p class="text-gray-700 leading-7">{{ 'privacy_recipients_desc'|trans }}</p>
        </section>

        {# 5 - STOCKAGE #}
        <section class="bg-white rounded-2xl shadow-md p-6 border border-theme-gray-100 hover:shadow-lg transition">
            <div class="flex items-center gap-3 mb-5">
                <div class="w-10 h-10 rounded-full bg-theme-green-100 flex items-center justify-center text-theme-green-700 font-bold">5</div>
                <h2 class="text-xl font-bold text-theme-gray-900">{{ 'privacy_storage'|trans }}</h2>
            </div>
            <p class="text-theme-gray-700 leading-7 mb-4">{{ 'privacy_storage_desc'|trans }}</p>
            <div class="grid md:grid-cols-2 gap-4">
                <div class="rounded-xl border bg-gray-50 p-4">
                    <h3 class="font-semibold text-gray-900 mb-1">{{ 'privacy_storage_accounting'|trans }}</h3>
                    <p class="text-sm text-gray-600">{{ 'privacy_storage_accounting_desc'|trans }}</p>
                </div>
                <div class="rounded-xl border bg-gray-50 p-4">
                    <h3 class="font-semibold text-gray-900 mb-1">{{ 'privacy_storage_contracts'|trans }}</h3>
                    <p class="text-sm text-gray-600">{{ 'privacy_storage_contracts_desc'|trans }}</p>
                </div>
                <div class="rounded-xl border bg-gray-50 p-4">
                    <h3 class="font-semibold text-gray-900 mb-1">{{ 'privacy_storage_claims'|trans }}</h3>
                    <p class="text-sm text-gray-600">{{ 'privacy_storage_claims_desc'|trans }}</p>
                </div>
                <div class="rounded-xl border bg-gray-50 p-4">
                    <h3 class="font-semibold text-gray-900 mb-1">{{ 'privacy_storage_client'|trans }}</h3>
                    <p class="text-sm text-gray-600">{{ 'privacy_storage_client_desc'|trans }}</p>
                </div>
            </div>
        </section>

        {# 6 - SECURITE #}
        <section class="bg-white rounded-2xl shadow-md p-6 border border-theme-gray-100 hover:shadow-lg transition">
            <div class="flex items-center gap-3 mb-4">
                <div class="w-10 h-10 rounded-full bg-theme-green-100 flex items-center justify-center text-theme-green-700 font-bold">6</div>
                <h2 class="text-xl font-bold text-theme-gray-900">{{ 'privacy_security'|trans }}</h2>
            </div>
            <p class="text-theme-gray-700 leading-7">{{ 'privacy_security_desc'|trans }}</p>
        </section>

        {# 7 - COOKIES #}
        <section class="bg-white rounded-2xl shadow-md p-6 border border-theme-gray-100 hover:shadow-lg transition">
            <div class="flex items-center gap-3 mb-5">
                <div class="w-10 h-10 rounded-full bg-theme-green-100 flex items-center justify-center text-theme-green-700 font-bold">7</div>
                <h2 class="text-xl font-bold text-theme-gray-900">{{ 'privacy_cookies'|trans }}</h2>
            </div>
            <div class="grid md:grid-cols-3 gap-4">
                <div class="rounded-xl bg-green-50 border border-green-100 p-4">
                    <h3 class="font-semibold text-green-800 mb-2">{{ 'privacy_cookies_functional'|trans }}</h3>
                    <p class="text-sm text-gray-700">{{ 'privacy_cookies_functional_desc'|trans }}</p>
                </div>
                <div class="rounded-xl bg-green-50 border border-green-100 p-4">
                    <h3 class="font-semibold text-green-800 mb-2">{{ 'privacy_cookies_stats'|trans }}</h3>
                    <p class="text-sm text-gray-700">{{ 'privacy_cookies_stats_desc'|trans }}</p>
                </div>
                <div class="rounded-xl bg-green-50 border border-green-100 p-4">
                    <h3 class="font-semibold text-green-800 mb-2">{{ 'privacy_cookies_third_party'|trans }}</h3>
                    <p class="text-sm text-gray-700">{{ 'privacy_cookies_third_party_desc'|trans }}</p>
                </div>
            </div>
        </section>

        {# 8 - DROITS #}
        <section class="bg-white rounded-2xl shadow-md p-6 border border-theme-gray-100 hover:shadow-lg transition">
            <div class="flex items-center gap-3 mb-5">
                <div class="w-10 h-10 rounded-full bg-theme-green-100 flex items-center justify-center text-theme-green-700 font-bold">8</div>
                <h2 class="text-xl font-bold text-theme-gray-900">{{ 'privacy_rights'|trans }}</h2>
            </div>
            <ul class="list-disc pl-5 text-gray-700 space-y-2 leading-7">
                <li>{{ 'privacy_rights_access'|trans }}</li>
                <li>{{ 'privacy_rights_rectification'|trans }}</li>
                <li>{{ 'privacy_rights_erasure'|trans }}</li>
                <li>{{ 'privacy_rights_opposition'|trans }}</li>
                <li>{{ 'privacy_rights_limitation'|trans }}</li>
                <li>{{ 'privacy_rights_portability'|trans }}</li>
            </ul>
        </section>

        {# CTA #}
        <div class="bg-theme-green-700 text-white rounded-3xl p-8 shadow-xl text-center">
            <h2 class="text-2xl font-bold mb-3">{{ 'legal_cta_title'|trans }}</h2>
            <p class="text-theme-green-100 mb-6">{{ 'legal_cta_desc'|trans }}</p>
            <a href="{{ path('homepage', {_locale: app.request.locale}) }}"
               class="inline-block px-6 py-3 bg-white text-theme-green-700 font-semibold rounded-xl shadow hover:scale-105 transition">
                {{ 'legal_cta_button'|trans }}
            </a>
        </div>

    </div>
</div>
{% endblock %}
