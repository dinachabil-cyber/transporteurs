{% extends 'base.html.twig' %}

{% block title %}Mentions légales{% endblock %}

{% block body %}
<div class="relative min-h-screen bg-gradient-to-br from-green-100 via-white to-emerald-100 py-16 px-4 overflow-hidden">

    {# BACKGROUND BLOBS #}
